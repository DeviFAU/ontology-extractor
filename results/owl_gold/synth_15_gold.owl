<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:ns1="http://example.org/music#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="http://example.org/music#albumTitle">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">albumTitle</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/music#Album"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/music#releasedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">releasedBy</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/music#Album"/>
    <rdfs:range rdf:resource="http://example.org/music#RecordLabel"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/music#Genre">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Genre</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/music#Instrument">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Instrument</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/music#emiRecords">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/music#RecordLabel"/>
    <rdfs:label xml:lang="en">emiRecords</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/music#plays">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">plays</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/music#Artist"/>
    <rdfs:range rdf:resource="http://example.org/music#Instrument"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/music#onAlbum">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">onAlbum</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/music#Song"/>
    <rdfs:range rdf:resource="http://example.org/music#Album"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/music#producedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">producedBy</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/music#Album"/>
    <rdfs:range rdf:resource="http://example.org/music#Producer"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/music#duration">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">duration</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/music#Song"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/music#Award">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Award</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/music#Studio">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Studio</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/music#abbeyRoad">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/music#Album"/>
    <rdfs:label xml:lang="en">abbeyRoad</rdfs:label>
    <ns1:albumTitle rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Abbey Road</ns1:albumTitle>
    <ns1:releaseYear rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1969</ns1:releaseYear>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/music#hasGenre">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">hasGenre</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/music#Album"/>
    <rdfs:range rdf:resource="http://example.org/music#Genre"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/music#Album">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Album</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/music#beatles">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/music#Band"/>
    <rdfs:label xml:lang="en">beatles</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/music#recordedAt">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">recordedAt</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/music#Album"/>
    <rdfs:range rdf:resource="http://example.org/music#Studio"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/music#Song">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Song</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/music#songTitle">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">songTitle</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/music#Song"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/music#comeTogther">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/music#Song"/>
    <rdfs:label xml:lang="en">comeTogther</rdfs:label>
    <ns1:songTitle rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Come Together</ns1:songTitle>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/music#wonAward">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">wonAward</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/music#Album"/>
    <rdfs:range rdf:resource="http://example.org/music#Award"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/music#Artist">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Artist</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/music#Producer">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Producer</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/music#RecordLabel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">RecordLabel</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/music#performedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">performedBy</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/music#Song"/>
    <rdfs:range rdf:resource="http://example.org/music#Artist"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/music#SoloArtist">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">SoloArtist</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/music#Artist"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/music#rock">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/music#Genre"/>
    <rdfs:label xml:lang="en">rock</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/music#Band">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Band</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/music#Artist"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/music#releaseYear">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">releaseYear</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/music#Album"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/music">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
  </rdf:Description>
</rdf:RDF>
