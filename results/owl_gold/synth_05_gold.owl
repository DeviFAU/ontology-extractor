<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="http://example.org/inverse#Child">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Child</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/inverse#hasChild">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">hasChild</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/inverse#Parent"/>
    <rdfs:range rdf:resource="http://example.org/inverse#Child"/>
    <owl:inverseOf rdf:resource="http://example.org/inverse#hasParent"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/inverse#hasParent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">hasParent</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/inverse#Child"/>
    <rdfs:range rdf:resource="http://example.org/inverse#Parent"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/inverse#Parent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Parent</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/inverse">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
  </rdf:Description>
</rdf:RDF>
