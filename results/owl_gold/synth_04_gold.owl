<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="http://example.org/instances#City">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">City</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/instances#locatedIn">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">locatedIn</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/instances#City"/>
    <rdfs:range rdf:resource="http://example.org/instances#Country"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/instances#munich">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/instances#City"/>
    <rdfs:label xml:lang="en">munich</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/instances#berlin">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/instances#City"/>
    <rdfs:label xml:lang="en">berlin</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/instances#germany">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/instances#Country"/>
    <rdfs:label xml:lang="en">germany</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/instances#Country">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Country</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/instances">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
  </rdf:Description>
</rdf:RDF>
