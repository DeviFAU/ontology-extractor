@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/ecommerce> a owl:Ontology .

<http://example.org/ecommerce#belongsTo> a owl:ObjectProperty ;
    rdfs:label "belongsTo"@en ;
    rdfs:domain <http://example.org/ecommerce#Product> ;
    rdfs:range <http://example.org/ecommerce#Category> .

<http://example.org/ecommerce#contains> a owl:ObjectProperty ;
    rdfs:label "contains"@en ;
    rdfs:domain <http://example.org/ecommerce#Order> ;
    rdfs:range <http://example.org/ecommerce#Product> .

<http://example.org/ecommerce#hasAddress> a owl:ObjectProperty ;
    rdfs:label "hasAddress"@en ;
    rdfs:domain <http://example.org/ecommerce#Customer> ;
    rdfs:range <http://example.org/ecommerce#ShippingAddress> .

<http://example.org/ecommerce#orderDate> a owl:DatatypeProperty ;
    rdfs:label "orderDate"@en ;
    rdfs:domain <http://example.org/ecommerce#Order> ;
    rdfs:range xsd:date .

<http://example.org/ecommerce#paidBy> a owl:ObjectProperty ;
    rdfs:label "paidBy"@en ;
    rdfs:domain <http://example.org/ecommerce#Order> ;
    rdfs:range <http://example.org/ecommerce#Payment> .

<http://example.org/ecommerce#places> a owl:ObjectProperty ;
    rdfs:label "places"@en ;
    rdfs:domain <http://example.org/ecommerce#Customer> ;
    rdfs:range <http://example.org/ecommerce#Order> .

<http://example.org/ecommerce#productName> a owl:DatatypeProperty ;
    rdfs:label "productName"@en ;
    rdfs:domain <http://example.org/ecommerce#Product> ;
    rdfs:range xsd:string .

<http://example.org/ecommerce#shippedTo> a owl:ObjectProperty ;
    rdfs:label "shippedTo"@en ;
    rdfs:domain <http://example.org/ecommerce#Order> ;
    rdfs:range <http://example.org/ecommerce#ShippingAddress> .

<http://example.org/ecommerce#totalPrice> a owl:DatatypeProperty ;
    rdfs:label "totalPrice"@en ;
    rdfs:domain <http://example.org/ecommerce#Order> ;
    rdfs:range xsd:double .

<http://example.org/ecommerce#Category> a owl:Class ;
    rdfs:label "Category"@en .

<http://example.org/ecommerce#Payment> a owl:Class ;
    rdfs:label "Payment"@en .

<http://example.org/ecommerce#Customer> a owl:Class ;
    rdfs:label "Customer"@en .

<http://example.org/ecommerce#ShippingAddress> a owl:Class ;
    rdfs:label "ShippingAddress"@en .

<http://example.org/ecommerce#Product> a owl:Class ;
    rdfs:label "Product"@en .

<http://example.org/ecommerce#Order> a owl:Class ;
    rdfs:label "Order"@en .

