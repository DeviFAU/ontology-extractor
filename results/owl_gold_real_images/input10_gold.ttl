<http://example.org/ontology#hasProgram> a owl:ObjectProperty ;
    rdfs:label "hasProgram"@en ;
    rdfs:domain <http://example.org/ontology#Customer> ;
    rdfs:range <http://example.org/ontology#Program> .

<http://example.org/ontology#ProcessFlow> a owl:Class ;
    rdfs:label "ProcessFlow"@en .

<http://example.org/ontology#Customer> a owl:Class ;
    rdfs:label "Customer"@en .

<http://example.org/ontology#Program> a owl:Class ;
    rdfs:label "Program"@en .

<http://example.org/ontology#ControlPlan> a owl:Class ;
    rdfs:label "ControlPlan"@en .

<http://example.org/ontology#PFMEA> a owl:Class ;
    rdfs:label "PFMEA"@en .

<http://example.org/ontology#DFMEA> a owl:Class ;
    rdfs:label "DFMEA"@en .

<http://example.org/ontology#DesignItem> a owl:Class ;
    rdfs:label "DesignItem"@en .

