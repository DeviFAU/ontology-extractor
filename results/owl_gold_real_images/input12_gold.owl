  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasZipCode">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">hasZipCode</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Address"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Order">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Order</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#City">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">City</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#deliverTo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">deliverTo</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Order"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Address"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Euro">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Euro</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#Currency"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#OrderId">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">OrderId</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Seller">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Seller</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#BusinessParty"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasSeller">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">hasSeller</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Order"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Seller"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Currency">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
