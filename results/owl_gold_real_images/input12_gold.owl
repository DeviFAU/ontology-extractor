<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="http://example.org/ontology#hasAddress">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">hasAddress</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#BusinessParty"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Address"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasCurrency">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">hasCurrency</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#BusinessParty"/>
    <rdfs:domain rdf:resource="http://example.org/ontology#Price"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Currency"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Price">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Price</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Buyer">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Buyer</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#BusinessParty"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasCountry">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">hasCountry</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#BusinessParty"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Country"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Country">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Country</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasItems">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">hasItems</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Order"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Item"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#USD">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">USD</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#Currency"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasName">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">hasName</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Item"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasCity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">hasCity</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Address"/>
    <rdfs:range rdf:resource="http://example.org/ontology#City"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Item">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Item</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Id">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Id</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#BusinessParty">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">BusinessParty</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasId">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">hasId</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Order"/>
    <rdfs:range rdf:resource="http://example.org/ontology#OrderId"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasPrice">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">hasPrice</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Item"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Price"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasStreet">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">hasStreet</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Address"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Address">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Address</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#billTo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">billTo</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Order"/>
