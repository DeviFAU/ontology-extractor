@prefix ns1: <http://example.org/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/ontology> a owl:Ontology .

ns1:Award a owl:Class ;
    rdfs:label "Award"@en .

ns1:Instrument a owl:Class ;
    rdfs:label "Instrument"@en .

ns1:Producer a owl:Class ;
    rdfs:label "Producer"@en .

ns1:SoloArtist a owl:Class ;
    rdfs:label "SoloArtist"@en ;
    rdfs:subClassOf ns1:Artist .

ns1:Studio a owl:Class ;
    rdfs:label "Studio"@en .

ns1:abbeyRoad a ns1:Album,
        owl:NamedIndividual ;
    rdfs:label "abbeyRoad"@en ;
    ns1:albumTitle "xsd:string"^^xsd:string ;
    ns1:releaseYear "xsd:integer"^^xsd:integer .

ns1:albumTitle a owl:DatatypeProperty ;
    rdfs:label "albumTitle"@en ;
    rdfs:domain ns1:Album ;
    rdfs:range xsd:string .

ns1:beatles a ns1:Band,
        owl:NamedIndividual ;
    rdfs:label "beatles"@en .

ns1:comeTogther a ns1:Song,
        owl:NamedIndividual ;
    rdfs:label "comeTogther"@en ;
    ns1:duration "xsd:double"^^xsd:double ;
    ns1:songTitle "xsd:string"^^xsd:string .

ns1:duration a owl:DatatypeProperty ;
    rdfs:label "duration"@en ;
    rdfs:domain ns1:Song ;
    rdfs:range xsd:double .

ns1:emiRecords a ns1:RecordLabel,
        owl:NamedIndividual ;
    rdfs:label "emiRecords"@en .

ns1:hasGenre a owl:ObjectProperty ;
    rdfs:label "hasGenre"@en .

ns1:onAlbum a owl:ObjectProperty ;
    rdfs:label "onAlbum"@en .

ns1:performedBy a owl:ObjectProperty ;
    rdfs:label "performedBy"@en .

ns1:plays a owl:ObjectProperty ;
    rdfs:label "plays"@en .

ns1:producedBy a owl:ObjectProperty ;
    rdfs:label "producedBy"@en .

ns1:recordedAt a owl:ObjectProperty ;
    rdfs:label "recordedAt"@en .

ns1:releaseYear a owl:DatatypeProperty ;
    rdfs:label "releaseYear"@en ;
    rdfs:domain ns1:Album ;
    rdfs:range xsd:integer .

ns1:releasedBy a owl:ObjectProperty ;
    rdfs:label "releasedBy"@en .

ns1:rock a ns1:Genre,
        owl:NamedIndividual ;
    rdfs:label "rock"@en .

ns1:songTitle a owl:DatatypeProperty ;
    rdfs:label "songTitle"@en ;
    rdfs:domain ns1:Song ;
    rdfs:range xsd:string .

ns1:wonAward a owl:ObjectProperty ;
    rdfs:label "wonAward"@en .

ns1:Band a owl:Class ;
    rdfs:label "Band"@en ;
    rdfs:subClassOf ns1:Artist .

ns1:Genre a owl:Class ;
    rdfs:label "Genre"@en .

ns1:RecordLabel a owl:Class ;
    rdfs:label "RecordLabel"@en .

ns1:Artist a owl:Class ;
    rdfs:label "Artist"@en .

ns1:Album a owl:Class ;
    rdfs:label "Album"@en .

ns1:Song a owl:Class ;
    rdfs:label "Song"@en .

