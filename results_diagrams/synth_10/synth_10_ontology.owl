<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="http://example.org/ontology#Allergy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Allergy</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasAllergy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">hasAllergy</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Patient"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Allergy"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#dateOfBirth">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">dateOfBirth</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Patient"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasTreatment">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">hasTreatment</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Diagnosis"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Treatment"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasDiagnosis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">hasDiagnosis</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Patient"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Diagnosis"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Hospital">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Hospital</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#prescribes">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">prescribes</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Treatment"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Medication"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Diagnosis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Diagnosis</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#treatedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">treatedBy</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Patient"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Doctor"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#patientID">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">patientID</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Patient"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#worksAt">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">worksAt</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Doctor"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Hospital"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Patient">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Patient</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Doctor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Doctor</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Treatment">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Treatment</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Medication">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Medication</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
  </rdf:Description>
</rdf:RDF>
