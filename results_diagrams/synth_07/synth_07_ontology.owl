<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="http://example.org/ontology#orderDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">orderDate</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Order"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#paidBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">paidBy</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Order"/>
    <rdfs:domain rdf:resource="http://example.org/ontology#Payment"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Payment"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Order">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Order</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#shippedTo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">shippedTo</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Order"/>
    <rdfs:range rdf:resource="http://example.org/ontology#ShippingAddress"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#totalPrice">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">totalPrice</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Order"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasAddress">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">hasAddress</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Customer"/>
    <rdfs:range rdf:resource="http://example.org/ontology#ShippingAddress"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#belongsTo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">belongsTo</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Product"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Category"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Product">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Product</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#contains">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">contains</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Order"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Product"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#productName">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">productName</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Product"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Payment">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Payment</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Customer">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Customer</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ShippingAddress">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">ShippingAddress</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#places">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">places</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Customer"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Order"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Category">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Category</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
  </rdf:Description>
</rdf:RDF>
