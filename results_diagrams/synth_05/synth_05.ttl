@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/ontology> a owl:Ontology .

<http://example.org/ontology#hasChild> a owl:ObjectProperty ;
    rdfs:label "hasChild"@en ;
    rdfs:domain <http://example.org/ontology#Parent> ;
    rdfs:range <http://example.org/ontology#Child> ;
    owl:inverseOf <http://example.org/ontology#hasParent> .

<http://example.org/ontology#hasParent> a owl:ObjectProperty ;
    rdfs:label "hasParent"@en ;
    rdfs:domain <http://example.org/ontology#Child> ;
    rdfs:range <http://example.org/ontology#Parent> .

<http://example.org/ontology#Child> a owl:Class ;
    rdfs:label "Child"@en .

<http://example.org/ontology#Parent> a owl:Class ;
    rdfs:label "Parent"@en .

