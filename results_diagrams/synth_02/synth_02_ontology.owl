<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:ns1="http://example.org/ontology#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="http://example.org/ontology#hasAge">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">hasAge</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Person"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <rdfs:comment xml:lang="en">Example value: 30</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Person">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Person</rdfs:label>
    <ns1:hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">John</ns1:hasName>
    <ns1:hasAge rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">30</ns1:hasAge>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#livesAt">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">livesAt</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Person"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Address"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasEmail">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">hasEmail</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Person"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Address">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Address</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasName">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">hasName</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Person"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment xml:lang="en">Example value: John</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
  </rdf:Description>
</rdf:RDF>
